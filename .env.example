# Copy to .env (gitignored). The justfile loads it automatically, so `just main`
# picks these up without you exporting anything.

# --- LLM ----------------------------------------------------------------------
# Free OpenAI-compatible providers, catalogued at
# https://github.com/cheahjs/free-llm-api-resources
# Set LLM_PROVIDER, then fill in that provider's key below.
#
#   google | groq | cerebras | openrouter | mistral | logfare | opencode
LLM_PROVIDER=google

GOOGLE_API_KEY=...          # aistudio.google.com/apikey  (default provider)
# GROQ_API_KEY=...          # console.groq.com/keys
# CEREBRAS_API_KEY=...      # cloud.cerebras.ai
# OPENROUTER_API_KEY=...    # openrouter.ai/keys
# MISTRAL_API_KEY=...       # console.mistral.ai
# LOGFARE_API_KEY=...       # logfare.ai — free, but logs all traffic
# OPENCODE_API_KEY=sk-...   # the original paid provider

# NOTE: LLM_API_URL overrides the provider's URL. Leave it unset unless you
# really mean it — a leftover value silently defeats LLM_PROVIDER.

# Optional — override the provider's default model (run `just models` to see
# what your key can reach; free line-ups change often).
# LLM_MODEL=gemini-2.5-flash

# --- STT ----------------------------------------------------------------------
# Optional — only if the STT service runs somewhere other than the default.
# WHISPER_SERVICE_URL=http://127.0.0.1:8001
