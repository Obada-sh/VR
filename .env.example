# Copy to .env (gitignored). The justfile loads it automatically, so `just main`
# picks these up without you exporting anything.
#
# NOTE: values are read by just's dotenv parser — an inline "# comment" after a
# value is stripped, but keep keys on their own line to be safe.

# --- LLM ----------------------------------------------------------------------
# Free OpenAI-compatible providers, catalogued at
# https://github.com/cheahjs/free-llm-api-resources
#
# This is an ordered FAILOVER CHAIN, not a single choice: each request tries the
# links left to right until one answers. A link is "provider" (its default
# model) or "provider:model", and the same provider may repeat with different
# models — that is how a strong-but-busy model sits in front of a reliable one.
#
# Measured 2026-07-20 on this account:
#   gemini-3.1-flash-lite  fast, reliable, best تشكيل of all tested -> first
#   groq llama-3.3-70b  works, but "corrects" كتير -> كثير (Fusha)  -> backup
#   gemini-3.5-flash    stronger, but 503s constantly and sometimes hangs
#                       to a read timeout — costly, since each patient turn
#                       makes TWO calls. Add it in front only if you want its
#                       quality and can absorb the stalls.
#   gemini-2.5-flash    RETIRED by Google — 404s
#   cerebras            402 Payment Required on this key            -> unused
LLM_PROVIDERS=google:gemini-3.1-flash-lite,groq

# Seconds before giving up on a provider. Non-final links use the shorter leash
# so one hanging provider can't stall the whole request.
# LLM_TIMEOUT=60
# LLM_FAILOVER_TIMEOUT=20

GOOGLE_API_KEY=...          # aistudio.google.com/apikey
GROQ_API_KEY=...            # console.groq.com/keys
# CEREBRAS_API_KEY=...      # cloud.cerebras.ai
# OPENROUTER_API_KEY=...    # openrouter.ai/keys
# MISTRAL_API_KEY=...       # console.mistral.ai
# OPENCODE_API_KEY=sk-...   # the original paid provider

# Optional — change a provider's default model without touching the chain.
# Free line-ups change fast: gemini-2.5-flash was retired out from under us.
# Run `just models` to see what each key can actually reach.
# GOOGLE_MODEL=gemini-3.1-flash-lite
# GROQ_MODEL=llama-3.1-8b-instant

# --- STT ----------------------------------------------------------------------
# Optional — only if the STT service runs somewhere other than the default.
# WHISPER_SERVICE_URL=http://127.0.0.1:8001
